# ==============================
# Fizzy digest instance runtime
# ==============================
FIZZY_PORT=3333
FIZZY_SECRET_KEY_BASE=replace_with_openssl_rand_hex_64
FIZZY_DISABLE_SSL=true
FIZZY_TLS_DOMAIN=
FIZZY_BASE_URL=http://localhost:3333
FIZZY_MULTI_TENANT=false

# Optional but needed for email login + notifications
FIZZY_MAILER_FROM_ADDRESS=
FIZZY_SMTP_ADDRESS=
FIZZY_SMTP_PORT=587
FIZZY_SMTP_USERNAME=
FIZZY_SMTP_PASSWORD=
FIZZY_SMTP_DOMAIN=
FIZZY_SMTP_AUTHENTICATION=plain
FIZZY_SMTP_TLS=
FIZZY_SMTP_SSL_VERIFY_MODE=

# ==============================
# fizzy.py CLI config
# ==============================
FIZZY_API_BASE_URL=http://localhost:3333
FIZZY_API_TOKEN=
FIZZY_ACCOUNT_SLUG=
FIZZY_BOARD_NAME="Digest Product Action Items"
